DATABASE_URL=sqlite:///./fracfocus_data/fracfocus.db
ZIP_URL=https://www.fracfocusdata.org/digitaldownload/FracFocusCSV.zip
EXTRACT_DIR=./fracfocus_data/extracted

SYNC_ENABLED=true
SYNC_CRON_DAY=1
SYNC_CRON_HOUR=2

REQUEST_TIMEOUT=120
DOWNLOAD_CHUNK_SIZE=1048576

TEXNET_REST_URL=https://maps.texnet.beg.utexas.edu/arcgis/rest/services/catalog/catalog_all/MapServer/0
TEXNET_BBOX_MIN_LAT=28.5
TEXNET_BBOX_MAX_LAT=32.5
TEXNET_BBOX_MIN_LON=-105.5
TEXNET_BBOX_MAX_LON=-102.5

USGS_FDSN_URL=https://earthquake.usgs.gov/fdsnws/event/1/query
USGS_MIN_MAGNITUDE=1.5
USGS_START_TIME=2000-01-01

API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
